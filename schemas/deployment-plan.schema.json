{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/deployment-plan.schema.json",
  "title": "AppLens-LLM Deployment Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "machine_class",
    "workload",
    "recommended_runtime",
    "safe_jobs",
    "gated_jobs",
    "validation"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "plan_id": { "type": "string", "minLength": 1 },
    "machine_class": {
      "type": "string",
      "enum": [
        "cpu_only",
        "small_local_ai_worker",
        "mid_local_ai_workstation",
        "large_local_ai_workstation",
        "remote_or_cloud_required"
      ]
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "intent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "intent": {
          "type": "string",
          "enum": ["inference", "benchmark", "dataset_prep", "tiny_training_smoke", "training", "agent_runtime"]
        }
      }
    },
    "recommended_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "model", "quantization", "launch_profile"],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["llama.cpp", "ollama", "jan", "vllm", "sglang", "transformers", "remote"]
        },
        "model": { "type": "string", "minLength": 1 },
        "quantization": { "type": "string", "minLength": 1 },
        "launch_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["context_tokens", "threads", "gpu_layers", "host", "port"],
          "properties": {
            "context_tokens": { "type": "integer", "minimum": 512 },
            "threads": { "type": "integer", "minimum": 1 },
            "gpu_layers": { "type": "integer", "minimum": 0 },
            "host": { "type": "string", "enum": ["127.0.0.1"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "extra_flags": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "safe_jobs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read_only_scan", "benchmark", "eval_sweep", "dataset_prep", "local_inference"]
      },
      "uniqueItems": true
    },
    "gated_jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["job", "gate"],
        "properties": {
          "job": {
            "type": "string",
            "enum": ["training", "large_download", "service_change", "driver_change", "network_exposure", "file_deletion"]
          },
          "gate": {
            "type": "string",
            "enum": ["user_approval", "admin_required", "unsupported", "manifest_required"]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "risk", "evidence", "guidance", "verification"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["Hardware", "Runtime", "Model", "Storage", "Training", "Safety", "Benchmark"]
          },
          "risk": { "type": "string", "enum": ["Info", "Low", "Medium", "High"] },
          "evidence": { "type": "string", "minLength": 1 },
          "guidance": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_benchmark", "requires_user_approval", "policy_notes"],
      "properties": {
        "requires_benchmark": { "type": "boolean" },
        "requires_user_approval": { "type": "boolean" },
        "policy_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
