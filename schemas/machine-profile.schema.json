{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/machine-profile.schema.json",
  "title": "AppLens-LLM Machine Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "machine_id",
    "label",
    "capture_status",
    "capture_priority",
    "platform",
    "hardware_topology",
    "target_roles",
    "collection",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "machine_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "label": { "type": "string", "minLength": 1 },
    "capture_status": {
      "type": "string",
      "enum": ["pending_capture", "captured_raw", "captured_sanitized", "deferred"]
    },
    "capture_priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "model", "sku", "os_family", "cpu", "ram_gb", "gpu", "vram_mb"],
      "properties": {
        "vendor": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "sku": { "type": "string", "minLength": 1 },
        "os_family": {
          "type": "string",
          "enum": ["windows", "linux", "macos", "unknown"]
        },
        "cpu": { "type": "string", "minLength": 1 },
        "ram_gb": { "type": "integer", "minimum": 0 },
        "gpu": { "type": "string", "minLength": 1 },
        "vram_mb": { "type": "integer", "minimum": 0 }
      }
    },
    "hardware_topology": {
      "$ref": "https://csi-platform.local/applens-llm/hardware-topology.schema.json"
    },
    "target_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "training_candidate",
          "serving_candidate",
          "cpu_baseline",
          "small_gpu_baseline",
          "workstation_baseline",
          "thin_laptop_baseline",
          "mac_baseline",
          "policy_edge_case"
        ]
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applens_report",
        "applens_tune_report",
        "local_ai_profile",
        "llm_bench",
        "sanitized"
      ],
      "properties": {
        "applens_report": { "$ref": "#/$defs/collection_status" },
        "applens_tune_report": { "$ref": "#/$defs/collection_status" },
        "local_ai_profile": { "$ref": "#/$defs/collection_status" },
        "llm_bench": { "$ref": "#/$defs/collection_status" },
        "sanitized": { "type": "boolean" }
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "collection_status": {
      "type": "string",
      "enum": ["pending", "captured", "not_applicable"]
    }
  }
}
