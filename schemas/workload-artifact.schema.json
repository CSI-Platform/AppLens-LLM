{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/workload-artifact.schema.json",
  "title": "AppLens-LLM Workload Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "workload_id",
    "run_id",
    "artifact_type",
    "path",
    "schema",
    "created_by",
    "summary",
    "hash",
    "privacy"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "workload_id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
    "run_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "schema": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "pattern": "^sha256:[a-zA-Z0-9]+$" },
    "privacy": { "$ref": "#/$defs/privacy" }
  },
  "$defs": {
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_safe", "local_paths_included"],
      "properties": {
        "commit_safe": { "type": "boolean" },
        "local_paths_included": { "type": "boolean" }
      }
    }
  }
}
