{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/runtime-lanes.schema.json",
  "title": "AppLens-LLM Runtime Lanes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lanes"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane" }
    }
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "role",
        "engine",
        "backend",
        "endpoint",
        "model",
        "device",
        "launch"
      ],
      "properties": {
        "lane_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "role": {
          "type": "string",
          "enum": ["fast", "deep", "baseline", "planner", "critic", "verifier", "worker"]
        },
        "engine": {
          "type": "string",
          "enum": ["llama.cpp", "openai-compatible", "jan", "ollama", "unknown"]
        },
        "backend": {
          "type": "string",
          "enum": [
            "cuda",
            "vulkan",
            "rocm",
            "hip",
            "directml",
            "metal",
            "openvino",
            "cpu",
            "rpc",
            "unknown"
          ]
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "model": { "$ref": "#/$defs/model" },
        "device": { "$ref": "#/$defs/device" },
        "launch": { "$ref": "#/$defs/launch" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "path"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "quantization": { "type": "string", "minLength": 1 },
        "context_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "accelerator_ids"],
      "properties": {
        "selector": { "type": "string", "minLength": 1 },
        "accelerator_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_binary", "context_tokens", "gpu_layers", "threads", "environment"],
      "properties": {
        "server_binary": { "type": "string", "minLength": 1 },
        "context_tokens": { "type": "integer", "minimum": 1 },
        "gpu_layers": { "type": "integer", "minimum": 0 },
        "threads": { "type": "integer", "minimum": 1 },
        "environment": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
