{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/model-fit-scorecard.schema.json",
  "title": "AppLens-LLM Model Fit Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scorecard_id",
    "created_at",
    "machine",
    "scoring_weights",
        "rankings",
        "benchmark_suites",
        "evidence",
        "next_actions",
        "privacy"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "scorecard_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["machine_id", "label", "platform"],
      "properties": {
        "machine_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpu", "gpu", "ram_gb", "os_family"],
          "properties": {
            "cpu": { "type": "string" },
            "gpu": { "type": "string" },
            "ram_gb": { "type": "integer", "minimum": 0 },
            "os_family": { "type": "string" }
          }
        }
      }
    },
    "scoring_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capacity_fit",
        "speed_latency",
        "stability",
        "role_fit",
        "quality_size",
        "operational_readiness",
        "evidence_confidence",
        "agent_capability",
        "context_evidence"
      ],
      "properties": {
        "capacity_fit": { "type": "integer", "const": 18 },
        "speed_latency": { "type": "integer", "const": 13 },
        "stability": { "type": "integer", "const": 10 },
        "role_fit": { "type": "integer", "const": 10 },
        "quality_size": { "type": "integer", "const": 5 },
        "operational_readiness": { "type": "integer", "const": 10 },
        "evidence_confidence": { "type": "integer", "const": 5 },
        "agent_capability": { "type": "integer", "const": 24 },
        "context_evidence": { "type": "integer", "const": 5 }
      }
    },
    "rankings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/model_ranking" }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_summary_count", "benchmark_record_count", "benchmark_suite_result_count", "capability_record_count", "candidate_model_count"],
      "properties": {
        "experiment_summary_count": { "type": "integer", "minimum": 0 },
        "benchmark_record_count": { "type": "integer", "minimum": 0 },
        "benchmark_suite_result_count": { "type": "integer", "minimum": 0 },
        "capability_record_count": { "type": "integer", "minimum": 0 },
        "candidate_model_count": { "type": "integer", "minimum": 0 }
      }
    },
    "benchmark_suites": {
      "type": "array",
      "items": { "$ref": "#/$defs/benchmark_suite_summary" }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workload_id", "roles"],
      "properties": {
        "workload_id": { "type": "string" },
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "capabilities"],
            "properties": {
              "role": { "type": "string" },
              "capabilities": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_safe", "local_paths_included"],
      "properties": {
        "commit_safe": { "type": "boolean" },
        "local_paths_included": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "model_ranking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "model_id",
        "display_name",
        "family",
        "parameter_size_b",
        "quantization",
        "local_status",
        "recommended_role",
        "best_lane",
        "fit_score",
        "score_band",
        "score_breakdown",
        "confidence",
        "reasons",
        "blockers",
        "evidence",
        "next_benchmark"
      ],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "parameter_size_b": { "type": "number", "minimum": 0 },
        "quantization": { "type": "string", "minLength": 1 },
        "local_status": {
          "type": "string",
          "enum": ["local", "candidate", "missing", "unknown"]
        },
        "recommended_role": {
          "type": "string",
          "enum": ["fast_chat", "deep_review", "coding", "summarization", "general_chat", "not_recommended"]
        },
        "best_lane": { "$ref": "#/$defs/lane_choice" },
        "fit_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "score_band": {
          "type": "string",
          "enum": ["excellent", "good", "usable", "experimental", "not_recommended"]
        },
        "score_breakdown": { "$ref": "#/$defs/score_breakdown" },
        "confidence": {
          "type": "string",
          "enum": ["observed", "inferred", "insufficient"]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "observation_count",
            "benchmark_suite_result_count",
            "benchmark_suite_passed",
            "benchmark_suite_failed",
            "benchmark_suite_unsupported",
            "benchmark_suite_unsupported_tasks",
            "capability_record_count",
            "thinking_modes",
            "advertised_context_tokens",
            "max_tested_context_tokens",
            "recommended_context_tokens",
            "context_score_pct",
            "context_evidence_status",
            "context_interpretation"
          ],
          "properties": {
            "source": { "type": "string", "minLength": 1 },
            "observation_count": { "type": "integer", "minimum": 0 },
            "benchmark_suite_result_count": { "type": "integer", "minimum": 0 },
            "benchmark_suite_passed": { "type": "integer", "minimum": 0 },
            "benchmark_suite_failed": { "type": "integer", "minimum": 0 },
            "benchmark_suite_unsupported": { "type": "integer", "minimum": 0 },
            "benchmark_suite_unsupported_tasks": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "capability_record_count": { "type": "integer", "minimum": 0 },
            "advertised_context_tokens": { "type": "integer", "minimum": 0 },
            "max_tested_context_tokens": { "type": "integer", "minimum": 0 },
            "recommended_context_tokens": { "type": "integer", "minimum": 0 },
            "context_score_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "context_evidence_status": {
              "type": "string",
              "enum": ["advertised_unproven", "observed_useful", "observed_limited", "not_advertised", "unknown"]
            },
            "context_interpretation": { "type": "string" },
            "capability_score_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "capability_categories": {
              "type": "object",
              "additionalProperties": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            },
            "thinking_modes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["on", "off", "auto", "unsupported", "unknown"]
              },
              "uniqueItems": true
            },
            "avg_latency_ms": { "type": "number", "minimum": 0 },
            "avg_total_tokens": { "type": "number", "minimum": 0 }
          }
        },
        "next_benchmark": { "type": "string", "minLength": 1 }
      }
    },
    "lane_choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_id", "backend", "accelerator_ids", "role"],
      "properties": {
        "lane_id": { "type": "string" },
        "backend": { "type": "string" },
        "accelerator_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "role": { "type": "string" },
        "model_label": { "type": "string" }
      }
    },
    "benchmark_suite_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_run_id",
        "model_id",
        "display_name",
        "suite_id",
        "status",
        "backend",
        "accelerator_ids",
        "condition_id",
        "total",
        "passed",
        "failed",
        "unsupported",
        "pending",
        "errored",
        "task_statuses"
      ],
      "properties": {
        "suite_run_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "suite_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "partial", "blocked", "fail", "pending"] },
        "backend": { "type": "string" },
        "accelerator_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "condition_id": { "type": "string" },
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "unsupported": { "type": "integer", "minimum": 0 },
        "pending": { "type": "integer", "minimum": 0 },
        "errored": { "type": "integer", "minimum": 0 },
        "task_statuses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["task_id", "benchmark", "category", "status", "metric_summary", "local_metric_summary", "notes"],
            "properties": {
              "task_id": { "type": "string" },
              "benchmark": { "type": "string" },
              "category": { "type": "string" },
              "status": { "type": "string" },
              "metric_summary": { "type": "string" },
              "local_metric_summary": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "score_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capacity_fit",
        "speed_latency",
        "stability",
        "role_fit",
        "quality_size",
        "operational_readiness",
        "evidence_confidence",
        "agent_capability",
        "context_evidence"
      ],
      "properties": {
        "capacity_fit": { "type": "integer", "minimum": 0, "maximum": 18 },
        "speed_latency": { "type": "integer", "minimum": 0, "maximum": 13 },
        "stability": { "type": "integer", "minimum": 0, "maximum": 10 },
        "role_fit": { "type": "integer", "minimum": 0, "maximum": 10 },
        "quality_size": { "type": "integer", "minimum": 0, "maximum": 5 },
        "operational_readiness": { "type": "integer", "minimum": 0, "maximum": 10 },
        "evidence_confidence": { "type": "integer", "minimum": 0, "maximum": 5 },
        "agent_capability": { "type": "integer", "minimum": 0, "maximum": 24 },
        "context_evidence": { "type": "integer", "minimum": 0, "maximum": 5 }
      }
    }
  }
}
