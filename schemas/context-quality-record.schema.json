{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csi-platform.local/applens-llm/context-quality-record.schema.json",
  "title": "AppLens-LLM Context Quality Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "benchmark",
    "model",
    "runtime",
    "probe",
    "scores",
    "cases",
    "outcome",
    "observation",
    "privacy"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "inspirations"],
      "properties": {
        "id": { "type": "string", "const": "applens-context-quality-v1" },
        "version": { "type": "string", "const": "0.1" },
        "inspirations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "model": { "$ref": "#/$defs/model" },
    "runtime": { "$ref": "#/$defs/runtime" },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context_tokens", "prompt_token_budget", "max_tokens", "expected_needle", "workloads"],
      "properties": {
        "context_tokens": { "type": "integer", "minimum": 1 },
        "prompt_token_budget": { "type": "integer", "minimum": 1 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "expected_needle": { "type": "string", "minLength": 1 },
        "workloads": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["long_context_retrieval", "strict_json", "coding", "hardware_memory_reasoning"]
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_points", "max_points", "quality_score_pct", "category_scores"],
      "properties": {
        "total_points": { "type": "number", "minimum": 0 },
        "max_points": { "type": "number", "exclusiveMinimum": 0 },
        "quality_score_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "category_scores": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["points", "max_points", "score_pct"],
            "properties": {
              "points": { "type": "number", "minimum": 0 },
              "max_points": { "type": "number", "exclusiveMinimum": 0 },
              "score_pct": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case_result" }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "band", "process_returncode", "elapsed_seconds", "notes"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "crash"] },
        "band": { "type": "string", "enum": ["useful_context", "limited", "not_recommended"] },
        "process_returncode": { "type": "integer" },
        "elapsed_seconds": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "observation": { "$ref": "#/$defs/context_observation" },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_safe", "local_paths_included"],
      "properties": {
        "commit_safe": { "type": "boolean" },
        "local_paths_included": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "display_name", "family", "parameter_size_b", "quantization"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "parameter_size_b": { "type": "number", "minimum": 0 },
        "quantization": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "backend", "device_selector", "devices_used"],
      "properties": {
        "engine": { "type": "string", "enum": ["llama.cpp", "ollama", "jan", "lm_studio", "unknown"] },
        "backend": {
          "type": "string",
          "enum": ["cuda", "vulkan", "rocm", "hip", "directml", "metal", "openvino", "cpu", "npu", "mixed", "unknown"]
        },
        "device_selector": { "type": "string", "minLength": 1 },
        "devices_used": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
        }
      }
    },
    "case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "category", "status", "points", "max_points", "issues", "checks", "response_excerpt"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["strict_json", "long_context_retrieval", "hardware_memory_reasoning", "coding", "context_selection"]
        },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "points": { "type": "number", "minimum": 0 },
        "max_points": { "type": "number", "exclusiveMinimum": 0 },
        "issues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "passed", "points", "max_points"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "passed": { "type": "boolean" },
              "points": { "type": "number", "minimum": 0 },
              "max_points": { "type": "number", "exclusiveMinimum": 0 },
              "notes": { "type": "string" }
            }
          }
        },
        "response_excerpt": { "type": "string" }
      }
    },
    "context_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "context_tokens",
        "backend",
        "devices_used",
        "status",
        "quality_score_pct",
        "generation_tokens_per_second",
        "prompt_tokens_per_second",
        "failure_modes",
        "workloads",
        "notes"
      ],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "context_tokens": { "type": "integer", "minimum": 1 },
        "backend": { "type": "string", "minLength": 1 },
        "devices_used": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "type": "string", "enum": ["pass", "fail", "oom", "timeout", "crash"] },
        "quality_score_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "generation_tokens_per_second": { "type": "number", "minimum": 0 },
        "prompt_tokens_per_second": { "type": "number", "minimum": 0 },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "workloads": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
